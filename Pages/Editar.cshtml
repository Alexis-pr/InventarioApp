@page "{id:int}"
@model EditarModel
@{
    ViewData["Title"] = "Editar Producto";
}

<h2>✏️ Editar Producto</h2>

<div class="col-md-5">
    <form method="post">
        <input type="hidden" asp-for="Producto.Id" />
        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input asp-for="Producto.Nombre" class="form-control" />
            <span asp-validation-for="Producto.Nombre" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Precio</label>
            <input asp-for="Producto.Precio" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="Producto.Precio" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Cantidad</label>
            <input asp-for="Producto.Cantidad" class="form-control" type="number" />
            <span asp-validation-for="Producto.Cantidad" class="text-danger"></span>
        </div>
        <button type="submit" class="btn btn-warning">Actualizar</button>
        <a href="/" class="btn btn-secondary">Cancelar</a>
    </form>
</div>
